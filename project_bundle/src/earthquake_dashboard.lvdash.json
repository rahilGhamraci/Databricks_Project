{
  "datasets": [
    {
      "name": "12984ff8",
      "displayName": "Earthquake_detail",
      "queryLines": [
        "select * from 02_silver.earthquake_data_final"
      ],
      "catalog": "dev",
      "schema": "02_silver"
    },
    {
      "name": "d7876e28",
      "displayName": "Earthquake_Type",
      "queryLines": [
        "select count(*) as total_magnitude_bucket, magnitude_bucket\r\n",
        "from ( \r\n",
        "    select case \r\n",
        "    when mag < 2 then 'micro (<2)'\r\n",
        "    when mag between 2 and 3 then 'minor (2-3)'\r\n",
        "    when mag between 3 and 4 then 'light (3-4)'\r\n",
        "    else 'moderate (4+)'\r\n",
        "    end as magnitude_bucket\r\n",
        "    from 02_silver.earthquake_data_final)\r\n",
        "group by magnitude_bucket"
      ],
      "catalog": "dev",
      "schema": "02_silver"
    },
    {
      "name": "55dfd271",
      "displayName": "Earthquake_Country",
      "queryLines": [
        "select count(*) as event_count,\r\n",
        "CASE  \r\n",
        "when size(split(place, ', ')) = 1 then split(place, ', ')[0]\r\n",
        "else split(place, ', ')[1]\r\n",
        "end as country\r\n",
        "from ( select \r\n",
        "time,\r\n",
        "title,\r\n",
        "mag,\r\n",
        "longitude,\r\n",
        "place,\r\n",
        "latitude\r\n",
        "from 02_silver.earthquake_data_final)\r\n",
        "group by country "
      ],
      "catalog": "dev",
      "schema": "02_silver"
    }
  ],
